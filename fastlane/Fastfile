default_platform(:ios)

APP_IDENTIFIER = "com.wizycode.create"
SCHEME        = "Create"

def asc_api_key
  app_store_connect_api_key(
    key_id: ENV["ASC_KEY_ID"],
    issuer_id: ENV["ASC_ISSUER_ID"],
    key_content: ENV["ASC_KEY_P8_BASE64"],
    is_key_content_base64: true,
    in_house: false
  )
end

platform :ios do
  desc "Build + upload TestFlight"
  lane :beta do
    # Crée un keychain CI dédié et le déverrouille : évite le hang de codesign
    # (qui attend sinon un prompt keychain jamais affiché en CI headless).
    setup_ci(force: true)

    api_key = asc_api_key

    # Le numéro de build est injecté DANS le projet par XcodeGen au moment du
    # `xcodegen generate` (CURRENT_PROJECT_VERSION = ${BUILD_NUMBER}, cf. project.yml).
    # Le .xcodeproj étant régénéré à chaque run, on n'incrémente rien ici.

    match(type: "appstore", api_key: api_key, readonly: false)

    # Signature manuelle : câbler le profil match dans le projet généré (sinon
    # "requires a provisioning profile" à l'archive).
    update_code_signing_settings(
      use_automatic_signing: false,
      path: "#{SCHEME}.xcodeproj",
      team_id: ENV["TEAM_ID"],
      code_sign_identity: "Apple Distribution",
      bundle_identifier: APP_IDENTIFIER,
      profile_name: "match AppStore #{APP_IDENTIFIER}"
    )

    build_app(
      scheme: SCHEME,
      export_method: "app-store",
      export_options: {
        signingStyle: "manual",
        provisioningProfiles: { APP_IDENTIFIER => "match AppStore #{APP_IDENTIFIER}" }
      }
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true
    )
  end

  desc "Build + soumission App Store (review)"
  lane :release do
    api_key = asc_api_key
    # Numéro de build fourni par XcodeGen (${BUILD_NUMBER}) au `xcodegen generate` — pas d'incrément ici.
    match(type: "appstore", api_key: api_key, readonly: false)
    build_app(scheme: SCHEME, export_method: "app-store",
              export_options: { signingStyle: "manual" })
    upload_to_app_store(
      api_key: api_key,
      submit_for_review: true,
      automatic_release: true,
      force: true,
      precheck_include_in_app_purchases: false,
      submission_information: { add_id_info_uses_idfa: false }
    )
  end
end
